# WSI Tissue Pipeline Configuration
# Copy this file to .env and customize as needed

# ============================================================================
# DATA PATHS
# ============================================================================
# Input directory containing VSI/ETS files
WSI_INPUT_DIR=/path/to/input/data

# Output directory for processed files
WSI_OUTPUT_DIR=/path/to/output/data

# ============================================================================
# PROCESSING OPTIONS
# ============================================================================
# Segmentation backend: local-entropy, local-otsu, tiatoolbox, pathml
WSI_SEGMENTATION_BACKEND=local-entropy

# Target size for tissue segmentation (longest edge in pixels)
WSI_TARGET_LONG_SIDE=2048

# Minimum tissue area in pixels (smaller regions are filtered)
WSI_MIN_AREA_PX=5000

# Output format: ome-zarr, tiff, or both
WSI_OUTPUT_FORMAT=ome-zarr

# Compression for output files: zlib, lz4, zstd, blosc, none
WSI_COMPRESSION=zlib

# Generate QC images
WSI_GENERATE_QC=true

# ============================================================================
# MLFLOW TRACKING
# ============================================================================
# MLflow tracking server URI (use sqlite for local, http for server)
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
# MLFLOW_TRACKING_URI=http://localhost:5000

# Experiment name for organizing runs
MLFLOW_EXPERIMENT_NAME=wsi-tissue-pipeline

# Log artifacts to MLflow (set to false for large datasets)
MLFLOW_LOG_ARTIFACTS=true

# ============================================================================
# DOCKER SETTINGS
# ============================================================================
# Host port for Jupyter Lab
JUPYTER_PORT=8888

# Host port for MLflow UI
MLFLOW_PORT=5000

# Host port for Neuroglancer
NEUROGLANCER_PORT=9999

# ============================================================================
# GOOGLE COLAB SETTINGS
# ============================================================================
# Mount Google Drive in Colab
COLAB_MOUNT_DRIVE=true

# Use GPU if available
COLAB_USE_GPU=true

# ============================================================================
# SCISERVER SETTINGS
# ============================================================================
# SciServer persistent storage path
SCISERVER_DATA_DIR=/home/idies/workspace/Storage

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================
# Number of parallel workers (0 = auto)
WSI_NUM_WORKERS=0

# Chunk size for processing (pixels)
WSI_CHUNK_SIZE=4096

# Memory limit per worker (GB)
WSI_MEMORY_LIMIT_GB=8

# Enable debug logging
WSI_DEBUG=false

# ============================================================================
# BIO-FORMATS / VSI METADATA
# ============================================================================
# Optional explicit Bio-Formats jar override
# WSI_PIPELINE_BIOFORMATS_JAR=/path/to/bioformats_package.jar

# Optional cache root override for the managed Bio-Formats jar
# WSI_PIPELINE_BIOFORMATS_CACHE_DIR=/path/to/bioformats-cache

# Disable automatic Bio-Formats jar download (set to 0/false/no/off)
# WSI_PIPELINE_BIOFORMATS_DOWNLOAD=0
